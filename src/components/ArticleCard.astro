---
import TagList from './TagList.astro';

interface Props {
  title: string;
  description: string;
  slug: string;
  type: 'guide' | 'tutorial';
  tags: string[];
  category: string;
  publishedAt: Date;
}

const { title, description, slug, type, tags, category, publishedAt } = Astro.props;
const href = `/${type}s/${slug}`;
const formattedDate = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const typeLabel = type === 'guide' ? 'Guide' : 'Tutorial';
---

<article class="border border-slate-200 rounded-lg p-5 hover:border-slate-400 transition-colors bg-white">
  <div class="flex items-center gap-2 text-xs text-slate-500 mb-2">
    <span class="inline-block bg-slate-100 text-slate-600 rounded px-1.5 py-0.5 font-medium uppercase tracking-wide">
      {typeLabel}
    </span>
    <span>&middot;</span>
    <span>{category}</span>
    <span>&middot;</span>
    <time datetime={publishedAt.toISOString()}>{formattedDate}</time>
  </div>
  <h2 class="text-lg font-semibold mb-2">
    <a href={href} class="text-slate-900 hover:text-blue-600">{title}</a>
  </h2>
  <p class="text-slate-600 text-sm mb-3">{description}</p>
  {tags.length > 0 && <TagList tags={tags} />}
</article>
