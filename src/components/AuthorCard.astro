---
import blogConfig from '../../blog.config.json';

const { author } = blogConfig;
---

<div class="flex items-start gap-4 p-4 bg-slate-100 rounded-lg">
  {author.avatar && (
    <img
      src={author.avatar}
      alt={author.name}
      class="w-16 h-16 rounded-full object-cover"
      loading="lazy"
    />
  )}
  <div>
    <p class="font-semibold text-slate-900">{author.name}</p>
    <p class="text-sm text-slate-600 mt-1">{author.bio}</p>
    {author.socialLinks && (
      <div class="flex gap-3 mt-2 text-sm">
        {Object.entries(author.socialLinks).map(([platform, url]) => (
          <a
            href={url}
            class="text-blue-600 hover:text-blue-800 capitalize"
            target="_blank"
            rel="noopener"
          >
            {platform}
          </a>
        ))}
      </div>
    )}
  </div>
</div>
