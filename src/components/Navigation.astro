---
import blogConfig from '../../blog.config.json';
---

<nav class="border-b border-slate-200 bg-white">
  <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="text-lg font-bold text-slate-900 hover:text-slate-700">
      {blogConfig.site.title}
    </a>
    <div class="flex items-center gap-4 text-sm">
      <a href="/" class="text-slate-600 hover:text-slate-900">All</a>
      <a href="/?filter=guide" class="text-slate-600 hover:text-slate-900">Guides</a>
      <a href="/?filter=tutorial" class="text-slate-600 hover:text-slate-900">Tutorials</a>
      <a href={blogConfig.agency.url} class="text-slate-600 hover:text-slate-900" target="_blank" rel="noopener">
        {blogConfig.agency.name} &rarr;
      </a>
    </div>
  </div>
</nav>
