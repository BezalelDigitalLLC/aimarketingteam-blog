---
import BaseLayout from './BaseLayout.astro';
import AuthorCard from '../components/AuthorCard.astro';
import TagList from '../components/TagList.astro';

interface Props {
  title: string;
  description: string;
  author: string;
  tags: string[];
  category: string;
  publishedAt: Date;
  type: 'guide' | 'tutorial';
}

const { title, description, author, tags, category, publishedAt, type } = Astro.props;
const formattedDate = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const typeLabel = type === 'guide' ? 'Guide' : 'Tutorial';
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="mb-8">
      <div class="flex items-center gap-2 text-sm text-slate-500 mb-3">
        <span class="inline-block bg-slate-200 text-slate-700 rounded px-2 py-0.5 font-medium text-xs uppercase tracking-wide">
          {typeLabel}
        </span>
        <span>&middot;</span>
        <span>{category}</span>
        <span>&middot;</span>
        <time datetime={publishedAt.toISOString()}>{formattedDate}</time>
      </div>
      <h1 class="text-4xl font-bold text-slate-900 mb-4">{title}</h1>
      <p class="text-lg text-slate-600">{description}</p>
      {tags.length > 0 && <TagList tags={tags} class="mt-4" />}
    </header>

    <div class="prose max-w-none">
      <slot />
    </div>

    <hr class="my-8 border-slate-200" />
    <AuthorCard />
  </article>
</BaseLayout>
